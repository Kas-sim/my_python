import pandas as pd

df = pd.read_json('TestEmployee.json')

num_of_employees = df['name'].count()
top_five_employees = df.head()

average_salary = df['salary'].mean()
highest_salary = df['salary'].max()
lowest_salary = df['salary'].min()


while True:
    x = int(input("\n0. 0 to Exit \n1. Number of Employees \n2. Check Top 5 Employees \n3. Check Salaries \n4. \nEnter Operation: "))
    if x == 0:
        break
    elif x == 1:
        print(num_of_employees)
    elif x == 2:
        print(top_five_employees)
    elif x == 3:
            y = int(input("\n1. Average Salary \n2. Highest Salary \n3. Lowest Salary \n4. All info \nEnter Operation: "))
            if y == 1:
                print(f"\n Average Salary -> { average_salary } \n")
            elif y == 2:
                print(f"\n Lowest Salary -> { highest_salary } \n")
            elif y == 3:
                print(f"\n Highest Salary -> { lowest_salary } \n")
            else:
                print(f"\n Average Salary -> { average_salary } \n")
                print(f"\n Lowest Salary -> { highest_salary } \n")
                print(f"\n Highest Salary -> { lowest_salary } \n")
    else:
        print("Invalid Operation!\n")
